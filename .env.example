# ============================================
# Meridian Monitor — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Meridian Monitor"

# --- Database (Supabase) ---
DATABASE_URL=postgresql://user:password@localhost:5432/meridian
DIRECT_URL=postgresql://user:password@localhost:5432/meridian

# --- Auth (NextAuth.js) ---
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Data Pipeline: GDELT ---
# No API key needed — GDELT is free and open

# --- Data Pipeline: ACLED ---
ACLED_API_KEY=your-acled-api-key
ACLED_EMAIL=your-email@example.com

# --- Data Pipeline: FRED (Federal Reserve Economic Data) ---
FRED_API_KEY=your-fred-api-key

# --- Data Pipeline: Google (Custom Search for OSINT) ---
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-cse-id

# --- Data Pipeline: OpenAI/GPT (Summarization) ---
OPENAI_API_KEY=sk-...

# --- Data Pipeline: Telegram Bot API ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Caching (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Feature Flags ---
NEXT_PUBLIC_FF_PREMIUM_ENABLED=false
NEXT_PUBLIC_FF_PROFESSIONAL_ENABLED=false
NEXT_PUBLIC_FF_ESCALATION_INDEX=true
NEXT_PUBLIC_FF_CONFLICT_MAP=false
NEXT_PUBLIC_FF_ECONOMIC_DASHBOARD=false
