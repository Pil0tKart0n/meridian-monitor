generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// Auth (NextAuth.js)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  tier          String    @default("FREE") // FREE, PREMIUM, PROFESSIONAL, ENTERPRISE
  stripeCustomerId String? @unique
  stripeSubscriptionId String?
  locale        String    @default("de")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ============================================
// News & Events
// ============================================

model NewsArticle {
  id            String   @id @default(cuid())
  externalId    String?  @unique
  title         String
  summary       String?
  content       String?
  url           String   @unique
  imageUrl      String?
  source        String
  sourceCountry String?
  category      String   @default("UNCATEGORIZED") // MILITARY, DIPLOMATIC, ECONOMIC, HUMANITARIAN, NUCLEAR, CYBER
  region        String?  // GAZA, ISRAEL, LEBANON, SYRIA, YEMEN, IRAN, IRAQ, RED_SEA, GULF, EUROPE, GLOBAL
  tone          Float?
  geiScore      Float    @default(0)
  publishedAt   DateTime
  fetchedAt     DateTime @default(now())
  language      String   @default("en")
  duplicateOfId String?
  duplicateOf   NewsArticle? @relation("Duplicates", fields: [duplicateOfId], references: [id])
  duplicates    NewsArticle[] @relation("Duplicates")

  @@index([publishedAt])
  @@index([source])
  @@index([category])
  @@index([region])
}

model ConflictEvent {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  source      String
  eventType   String
  category    String   // MILITARY, DIPLOMATIC, ECONOMIC, HUMANITARIAN, NUCLEAR, CYBER
  region      String?  // GAZA, ISRAEL, LEBANON, etc.
  latitude    Float?
  longitude   Float?
  country     String?
  location    String?
  actors      String?  // JSON array as string
  fatalities  Int      @default(0)
  description String?
  score       Float    @default(0)
  eventDate   DateTime
  fetchedAt   DateTime @default(now())

  @@index([eventDate])
  @@index([category])
  @@index([region])
}

// ============================================
// Global Escalation Index (GEI)
// ============================================

model EscalationSnapshot {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  overallScore    Float
  militaryScore   Float
  diplomaticScore Float
  conflictScore   Float
  economicScore   Float
  nuclearScore    Float
  primaryDriver   String?
  keyEvents       String?  // JSON array as string
  editorialAdjust Float    @default(0)

  @@index([timestamp])
}

// ============================================
// Market Data
// ============================================

model MarketDataPoint {
  id        String   @id @default(cuid())
  indicator String
  value     Float
  date      DateTime
  fetchedAt DateTime @default(now())

  @@unique([indicator, date])
  @@index([indicator, date])
}
