{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "mcp__playwright__*"
    ],
    "deny": [
      "Write(.env*)",
      "Write(.claude/settings.json)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp", "--headless"]
    }
  }
}
